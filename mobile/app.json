{
  "expo": {
    "name": "Work Logbook",
    "slug": "work-logbook",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": { "resizeMode": "contain", "backgroundColor": "#0f0f0f" },
    "android": {
      "adaptiveIcon": { "backgroundColor": "#0f0f0f" },
      "package": "com.worklogbook.app"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      "expo-secure-store",
      "expo-web-browser"
    ],
    "scheme": "worklogbook"
  }
}
